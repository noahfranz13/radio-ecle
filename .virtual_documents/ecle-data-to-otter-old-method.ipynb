


import pandas as pd
import numpy as np
import json as jj
from otter.util import bibcode_to_hrn
from otter import Otter

radio = pd.read_csv('ecle-radio-data.csv')
radio = radio[~pd.isna(radio.flux)]
radio = radio[radio.use_this] # this will reduce redundancy

ir = pd.read_csv('data/wise-photometry.csv')

meta = pd.read_csv('ecle-meta-data.csv')

data = pd.merge(meta, radio, on='name')

data


radio


db = Otter('ecle-otter')

db.generate_summary_table()


ecle_jsons = []

for name, ecle in data.groupby('name'):
    
    json = {}
    ecle = ecle.reset_index()
    
    # name first
    json['name'] = dict(
        default_name = name,
        alias = [dict(
            value = name,
            reference = [ecle.coord_ref[0]]
        )]
    )
    
    # coordinates
    json['coordinate'] = [dict(
        ra = ecle.ra[0],
        dec = ecle.dec[0],
        ra_units = ecle.ra_unit[0],
        dec_units = ecle.dec_unit[0],
        reference = [ecle.coord_ref[0]],
        coordinate_type = 'equitorial'
    )]
    
    # redshift
    json['distance'] = [dict(
        value = ecle.redshift[0],
        reference = [ecle.redshift_ref[0]],
        compute = False,
        distance_type = 'redshift'
    )]
    
    # classification
    if ecle.classification[0] in {'TDE', 'AGN'}:
        objclass = ecle.classification[0]
        objconf = 1
    else:
        # this is likely an AGN but with a low confidence
        objclass = 'AGN' 
        objconf = 0.1
        
    json['classification'] = [
        dict(
            object_class = 'ECLE',
            confidence = 1, # we know this is at least an ECLE
            reference = [ecle.classification_ref[0]]
        ),
        dict(
            object_class = objclass,
            confidence = objconf,
            reference = [ecle.classification_ref[0]]
        )
    ]
    
    # discovery date
    # print(ecle)
    if not np.any(pd.isna(ecle.discovery_date)):
        json['date_reference'] = [
            dict(
                value = ecle.discovery_date.tolist()[0].strip(),
                date_format = ecle.discovery_date_format.tolist()[0].lower(),
                reference = ecle.discovery_date_ref.tolist()[0],
                computed = False,
                date_type = 'discovery'
            )
        ]
    
    # now the radio photometry
    phot_sources = []
    json['photometry'] = []
    for src, phot in ecle.groupby('source'):
        
        if src not in phot_sources:
            phot_sources.append(src)
            
        if len(np.unique(phot.flux_unit)) == 1:
            # print(type(phot.flux_unit.values))
            raw_units = phot.flux_unit.tolist()[0]
        else:
            raw_units = phot.flux_unit.values
            
        json_phot = dict(
            reference = src, # since this is unpublished data we don't need it to be a bibcode
            raw = phot.flux.tolist(),
            raw_err = phot.flux_err.tolist(),
            raw_units = raw_units,
            date = phot.date_mjd.tolist(),
            date_format = 'mjd',
            upperlimit = phot.upperlimit.tolist(),
            telescope = 'VLA',
            filter_key = phot['filter'].tolist(),
            obs_type = 'radio',
            reducer = phot.reducer.tolist()
        )
        
        json['photometry'].append(json_phot)
        
    # now the IR photometry
    src = 'WISE'
    phot_ir = ir[ir.name == name]        
    
    if src not in phot_sources:
        phot_sources.append(src)
            
    if len(np.unique(phot_ir.flux_unit)) == 1:
        # print(type(phot.flux_unit.values))
        raw_units = phot_ir.flux_unit.tolist()[0]
    else:
        raw_units = phot_ir.flux_unit.tolist()
            
    json_phot = dict(
        reference = src, # since this is unpublished data we don't need it to be a bibcode
        raw = phot_ir.flux.tolist(),
        raw_err = phot_ir.flux_err.tolist(),
        raw_units = raw_units,
        date = phot_ir.date_mjd.tolist(),
        date_format = 'mjd',
        upperlimit = phot_ir.upperlimit.tolist(),
        telescope = 'WISE',
        filter_key = phot_ir['filter'].tolist(),
        obs_type = 'uvoir'
    )

    json['photometry'].append(json_phot)
    
    # filter alias
    # radio filters first
    filter_keys1 = ['filter', 'filter_eff', 'filter_eff_units']
    filter_keys2 = ['filter', 'filter_eff', 'filter_eff_unit'] 
    filter_map_radio = ecle[filter_keys1].drop_duplicates().set_index('filter')#.to_dict(orient='index')
    try:
        filter_map_radio = filter_map_radio.to_dict(orient='index')
    except:
        print(filter_map)
        print(name)
        raise Exception
    json['filter_alias'] = [dict(
        filter_key = filt,
        freq_eff = val['filter_eff'],
        freq_units = val['filter_eff_units']
    ) for filt, val in filter_map_radio.items() ]
    
    # the IR filters
    filter_map_ir = phot_ir[filter_keys2].drop_duplicates().set_index('filter').to_dict(orient='index')
    json['filter_alias'] += [dict(
        filter_key = filt,
        wave_eff = val['filter_eff'],
        wave_units = val['filter_eff_unit']
    ) for filt, val in filter_map_ir.items() ]
    
    print(json['filter_alias'])
    
    # reference alias
    json['reference_alias'] = [
        dict(
            name = ecle.coord_ref[0],
            human_readable_name = bibcode_to_hrn(ecle.coord_ref[0])
        )
    ] + [dict(name=val,human_readable_name=val) for val in phot_sources]
    
    curr_refs = {v['name'] for v in json['reference_alias']}
    if ecle.redshift_ref[0] not in curr_refs:
        json['reference_alias'].append(dict(
            name = ecle.redshift_ref[0],
            human_readable_name = bibcode_to_hrn(ecle.redshift_ref[0])
        ))
        
    curr_refs = {v['name'] for v in json['reference_alias']}
    if ecle.classification_ref[0] not in curr_refs:
        json['reference_alias'].append(dict(
            name = ecle.classification_ref[0],
            human_readable_name = bibcode_to_hrn(ecle.classification_ref[0])
        ))
        
    #     print(jj.dumps(json, indent=4))
    #     print('#############################################################################################')
    #     print()
    #     print()
    
    ecle_jsons.append(json)

